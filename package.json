{
  "name": "jest-react-mock",
  "version": "4.0.0",
  "description": "jest helper for react-mock-component",
  "keywords": [
    "jest",
    "react",
    "mock",
    "tdd",
    "testing",
    "expect"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiGhTTraX/jest-react-mock.git"
  },
  "author": "Andrei Picus",
  "license": "MIT",
  "homepage": "https://github.com/NiGhTTraX/jest-react-mock",
  "main": "dist/index",
  "types": "dist/index",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm run compile",
    "clean": "rm -rf ./dist",
    "compile": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "release": "standard-version",
    "lint": "eslint .",
    "test": "jest --config jest.config.ts --coverage"
  },
  "peerDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.0.0",
    "react-mock-component": "^5.0.0"
  },
  "devDependencies": {
    "@nighttrax/eslint-config-tsx": "~13.1.2",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.0",
    "@types/jest": "~30.0.0",
    "@types/react": "~19.2.0",
    "eslint": "~10.5.0",
    "prettier": "~3.8.4",
    "jest": "~30.4.0",
    "jest-environment-jsdom": "~30.4.0",
    "react": "~19.2.0",
    "react-dom": "~19.2.0",
    "react-mock-component": "~5.0.0",
    "standard-version": "~9.5.0",
    "strip-ansi": "~6.0.0",
    "ts-jest": "~29.4.11",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@11.6.0"
}
