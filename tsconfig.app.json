{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "strict": true,
    "lib": ["es6", "es2017", "dom"],
    "jsx": "react-jsx",
    "types": ["jest"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    // TODO: we catch JestAssertionError but the type is not available for import
    // see https://github.com/facebook/jest/issues/9919
    "useUnknownInCatchVariables": false
  },
  "exclude": ["node_modules", "tests", "dist"]
}
